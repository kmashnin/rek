function importExcel(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('import-status');
  status.style.display = 'block';
  status.style.color = 'var(--text3)';
  status.textContent = '⏳ Читаю файл...';

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const wb = XLSX.read(e.target.result, {type:'array', cellDates:true});

      let dealsAdded = 0, blogsAdded = 0;

      // ── Лист «Сделки» ──
      const dealsSheet = wb.Sheets['📋 Сделки'] || wb.Sheets['Сделки'] || wb.Sheets[Object.keys(wb.Sheets).find(n=>n.includes('Сделки'))];
      if (dealsSheet) {
        const rows = XLSX.utils.sheet_to_json(dealsSheet, {header:1, defval:''});
        // row[0] = title, row[1] = headers, row[2]+ = data
        // Cols: 0=№,1=Дата,2=Менеджер,3=Продукт,4=Блогер,5=Платформа,6=Ссылка,7=Подписчики,8=Сумма,9=ТипОплаты,10=ДатаОплаты,11=Статус,12=ДатаВыхода,13=ТипКонтента,14=Просмотры,15=Продажи,16=CPV,17=Комментарий
        for (let i = 2; i < rows.length; i++) {
          const r = rows[i];
          if (!r[4] || String(r[4]).trim() === '') continue; // нет блогера — пропуск
          const blogger = String(r[4]).trim();
          // skip if already exists
          if (state.deals.some(d => d.b.toLowerCase() === blogger.toLowerCase())) continue;

          const sum = parseFloat(String(r[8]).replace(/[^\d.]/g,'')) || 0;
          const views = parseFloat(String(r[14]).replace(/[^\d.]/g,'')) || null;
          const subs = parseFloat(String(r[7]).replace(/[^\d.]/g,'')) || null;
          const status = String(r[11]).trim() || 'Поиск';
          const validStatuses = ['Поиск','Переговоры','Ожидает оплаты','Бартер','Оплачено','Размещено','Отказ'];

          // format date
          function fmtDate(v) {
            if (!v) return null;
            if (v instanceof Date) return v.toISOString().split('T')[0];
            const s = String(v).trim();
            if (!s) return null;
            // DD.MM.YYYY
            const m = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
            if (m) return `${m[3]}-${m[2].padStart(2,'0')}-${m[1].padStart(2,'0')}`;
            return null;
          }

          state.deals.push({
            id: Date.now() + i,
            b: blogger,
            pl: String(r[5]).trim() || 'Другое',
            m: String(r[2]).trim() || '',
            pr: String(r[3]).trim() || '',
            s: sum,
            py: String(r[9]).trim() || 'Карта физлица',
            st: validStatuses.includes(status) ? status : 'Поиск',
            reach: subs,
            v: views || null,
            sl: parseFloat(String(r[15]).replace(/[^\d.]/g,'')) || null,
            dt: fmtDate(r[12]) || fmtDate(r[10]) || null,
            l: String(r[6]).trim() || '',
            c: String(r[17]).trim() || '',
            ctype: '', cval: '', del: '', addr: ''
          });
          dealsAdded++;
        }
      }

      // ── Лист «База блогеров» ──
      const blogSheet = wb.Sheets['📁 База блогеров'] || wb.Sheets['База блогеров'] || wb.Sheets[Object.keys(wb.Sheets).find(n=>n.includes('лог'))];
      if (blogSheet) {
        const rows = XLSX.utils.sheet_to_json(blogSheet, {header:1, defval:''});
        // Cols: 0=Блогер,1=Платформа,2=Ссылка,3=Подписчики,4=СрОхват,5=ERR,6=CPV,7=Ниша,8=Менеджер,9=Размещений,10=СрПросмотры,11=Цена,12=Особенности,13=Контакт,14=Статус
        for (let i = 2; i < rows.length; i++) {
          const r = rows[i];
          if (!r[0] || String(r[0]).trim() === '') continue;
          const name = String(r[0]).trim();
          if (state.blogs.some(b => b.n.toLowerCase() === name.toLowerCase())) continue;

          const price = String(r[11]).trim() || '—';
          const reach = parseFloat(String(r[4]).replace(/[^\d.]/g,'')) || null;
          const subs = parseFloat(String(r[3]).replace(/[^\d.]/g,'')) || null;
          const cpv = parseFloat(String(r[6]).replace(/[^\d.]/g,'')) || null;
          const deals = parseInt(String(r[9])) || 0;

          state.blogs.push({
            n: name,
            pl: String(r[1]).trim() || 'Другое',
            sb: subs,
            reach: reach,
            cpv: cpv,
            d: deals,
            p: price,
            c: String(r[12]).trim() || String(r[7]).trim() || ''
          });
          blogsAdded++;
        }
      }

      save();
      renderDash();
      renderSettings();

      status.style.color = 'var(--green)';
      status.textContent = `✅ Импортировано: ${dealsAdded} сделок, ${blogsAdded} блогеров`;
      input.value = '';
      showToast(`Импорт завершён: +${dealsAdded} сделок, +${blogsAdded} блогеров`);

    } catch(err) {
      status.style.color = 'var(--red)';
      status.textContent = '❌ Ошибка: ' + err.message;
      console.error(err);
    }
  };
  reader.readAsArrayBuffer(file);
}

// ── МЕСЯЦ ─────────────────────────────────────────────
function getDealMonth(d) {
  // priority: date of publication, else date of payment
  const raw = d.dt || null;
  if (!raw) return null;
  // format: YYYY-MM-DD or DD.MM.YYYY
  let y, m;
  if (raw.includes('-')) { const p=raw.split('-'); y=p[0]; m=p[1]; }
  else if (raw.includes('.')) { const p=raw.split('.'); y=p[2]; m=p[1]; }
  else return null;
  return `${y}-${m}`;
}

function getAvailableMonths() {
  const set = new Set();
  state.deals.forEach(d => { const m=getDealMonth(d); if(m) set.add(m); });
  return [...set].sort().reverse(); // newest first
}

function mthLabel(ym) {
  const [y, m] = ym.split('-');
  return MONTHS_RU[parseInt(m)-1] + ' ' + y.slice(2);
}

function renderMonthPills(containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  const months = getAvailableMonths();
  el.innerHTML = `<button class="pill ${activeMth==='all'?'on':''}" onclick="setMth('all')">Все</button>` +
    months.map(m => `<button class="pill ${activeMth===m?'on':''}" onclick="setMth('${m}')">${mthLabel(m)}</button>`).join('');
}

function setMth(mth) {
  activeMth = mth;
  // sync both pill bars
  ['month-pills','dash-month-pills'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    el.querySelectorAll('.pill').forEach(p => {
      const pm = p.textContent.trim();
      const isAll = pm === 'Все';
      const isActive = isAll ? mth==='all' : (mth!=='all' && mthLabel(mth)===pm);
      p.classList.toggle('on', isActive);
    });
  });
  renderDash();
  renderDeals();
}

function filterByMonth(deals) {
  if (activeMth === 'all') return deals;
  return deals.filter(d => getDealMonth(d) === activeMth);
}

// ── ПЕРЕМЕСТИТЬ В БАЗУ ────────────────────────────────
function moveToBloggerBase() {
  if (!aDId) return;
  const d = state.deals.find(x => x.id === aDId);
  if (!d) return;

  // Show reason picker
  const reasons = ['Дорого', 'Отказал сам', 'Не та аудитория', 'Плохой контент', 'Не отвечает', 'Другое'];
  const reasonHtml = reasons.map(r =>
    `<button onclick="confirmMoveToBase('${r}')" style="background:var(--surface2);border:.5px solid var(--border2);border-radius:var(--rsm);padding:10px 14px;font-size:14px;text-align:left;width:100%;margin-bottom:8px;cursor:pointer">${r}</button>`
  ).join('');

  document.getElementById('det-body').innerHTML = `
    <div style="margin-bottom:16px">
      <div style="font-size:15px;font-weight:600;margin-bottom:6px">Переместить в базу блогеров</div>
      <div style="font-size:13px;color:var(--text2);margin-bottom:16px">Блогер <b>${d.b}</b> будет добавлен в базу. Сделка будет удалена из списка и бюджета.</div>
      <div style="font-size:12px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px">Причина</div>
      ${reasonHtml}
      <button onclick="openDet(${aDId})" style="background:none;border:.5px solid var(--border2);color:var(--text2);border-radius:var(--rsm);padding:10px;font-size:14px;width:100%;cursor:pointer;margin-top:4px">Отмена</button>
    </div>`;
}

function confirmMoveToBase(reason) {
  if (!aDId) return;
  const d = state.deals.find(x => x.id === aDId);
  if (!d) return;

  // Add to bloggers base if not already there
  const exists = state.blogs.some(b => b.n.toLowerCase() === d.b.toLowerCase());
  if (!exists) {
    state.blogs.push({
      n: d.b,
      pl: d.pl,
      sb: d.reach || null,
      reach: d.reach || null,
      cpv: null,
      d: 0,
      p: d.s ? fR(d.s) : '—',
      c: d.c || '',
      reason: reason
    });
  } else {
    // Update reason if already in base
    const b = state.blogs.find(x => x.n.toLowerCase() === d.b.toLowerCase());
    if (b) b.reason = reason;
  }

  // Remove from deals
  state.deals = state.deals.filter(x => x.id !== aDId);
  save();
  closeDet();
  renderDash();
  renderDeals();
  renderBloggers();
  showToast(`${d.b} → База блогеров (${reason})`);
}

// Auto-move to base when status set to Отказ
const _origUpd = upd;
upd = function(id, f, v) {
  _origUpd(id, f, v);
  if (f === 'st' && v === 'Отказ') {
    aDId = id;
    moveToBloggerBase();
  }
};

// Swipe down to close drawers
function addSwipeClose(drawerId, closeFn) {
  const el = document.getElementById(drawerId);
  let startY = 0, startT = 0;
  el.addEventListener('touchstart', e => { startY = e.touches[0].clientY; startT = Date.now(); }, {passive:true});
  el.addEventListener('touchend', e => {
    const dy = e.changedTouches[0].clientY - startY;
    const dt = Date.now() - startT;
    if (dy > 60 && dt < 400) closeFn();
  }, {passive:true});
}
addSwipeClose('new-dr', closeNew);
addSwipeClose('det-dr', closeDet);
</script>
