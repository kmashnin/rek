function renderBudget(){
  const d=filterByMonth(state.deals);
  const paid=d.filter(x=>['Оплачено','Размещено'].includes(x.st)&&x.py!=='Бартер').reduce((a,x)=>a+x.s,0);
  const wait=d.filter(x=>x.st==='Ожидает оплаты').reduce((a,x)=>a+x.s,0);
  document.getElementById('b-paid').textContent=fR(paid);
  document.getElementById('b-wait').textContent=fR(wait);

  // Budget plan progress
  const plan=loadBudgetPlan();
  const planInput=document.getElementById('budget-plan');
  if(planInput&&!planInput.value&&plan) planInput.value=plan;
  const wrap=document.getElementById('budget-progress-wrap');
  if(plan>0){
    wrap.style.display='block';
    const pct=Math.min(Math.round(paid/plan*100),100);
    const over=paid>plan;
    const barColor=pct<70?'var(--green)':pct<90?'var(--amber)':'var(--red)';
    document.getElementById('budget-bar').style.width=pct+'%';
    document.getElementById('budget-bar').style.background=barColor;
    document.getElementById('budget-pct').textContent=pct+'%';
    document.getElementById('budget-pct').style.color=barColor;
    document.getElementById('budget-spent-lbl').textContent='Потрачено: '+fR(paid);
    document.getElementById('budget-remain-lbl').textContent=(over?'Перерасход: '+fR(paid-plan):'Остаток: '+fR(plan-paid));
    document.getElementById('budget-remain-lbl').style.color=over?'var(--red)':'var(--text3)';
  } else {
    wrap.style.display='none';
  }

  const rows=d.filter(x=>!['Поиск','Переговоры','Отказ'].includes(x.st));
  document.getElementById('budget-list').innerHTML=rows.length?rows.map(x=>{
    const tax=x.py==='Счёт/самозанятый'?Math.round(x.s*0.06):0;
    return`<div class="bud-item"><div class="bud-top"><div><div class="bud-name">${x.b}</div><div class="dc-plat" style="margin-top:2px">${x.m} · ${x.pr}</div></div><div class="bud-sum">${x.py==='Бартер'?'Бартер':fR(x.s+tax)}</div></div><div class="bud-meta">${bdg(x.st)}<span class="bud-pay">${x.py}</span>${tax?`<span class="bud-tax">налог ${fR(tax)}</span>`:''}</div></div>`;
  }).join(''):'<div class="empty">Нет данных</div>';
}

