<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Реклама — внешние размещения</title>
<style>
:root{--bg:#F7F6F3;--surface:#fff;--surface2:#F0EEE9;--border:#E2DFD8;--border2:#CBC8C0;--text:#1A1916;--text2:#6B6860;--text3:#9B9890;--purple:#6C5CE7;--purple-l:#EEF0FF;--purple-t:#4A3FB5;--green:#00A86B;--green-l:#E6F7F1;--green-t:#006E46;--amber:#D97706;--amber-l:#FEF3C7;--amber-t:#92400E;--blue:#2563EB;--blue-l:#EFF6FF;--blue-t:#1E40AF;--teal:#0D9488;--teal-l:#CCFBF1;--teal-t:#0F766E;--red:#DC2626;--red-l:#FEF2F2;--red-t:#991B1B;--gray-l:#F3F2EF;--gray-t:#4B4A47;--r:12px;--rsm:8px}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.45;overscroll-behavior:none}
button{cursor:pointer;font-family:inherit;font-size:15px;border:none;background:none}
.shell{display:flex;flex-direction:column;height:100dvh;max-width:430px;margin:0 auto;position:relative;overflow:hidden;background:var(--bg)}
.hdr{background:var(--surface);border-bottom:.5px solid var(--border);padding:12px 16px 10px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:10}
.hdr-title{font-size:17px;font-weight:600}
.hdr-sub{font-size:12px;color:var(--text3)}
.hdr-btn{background:var(--purple);color:#fff;border-radius:var(--rsm);padding:7px 13px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:5px}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:8px}
.bottom-nav{position:relative;bottom:0;background:var(--surface);border-top:.5px solid var(--border);display:flex;z-index:100;flex-shrink:0;padding-bottom:env(safe-area-inset-bottom)}
.bnav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:9px 4px 7px;color:var(--text3);font-size:10px;font-weight:500}
.bnav-btn svg{width:22px;height:22px;stroke-width:1.8}
.bnav-btn.on{color:var(--purple)}

.page{display:none}.page.on{display:block}
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:14px 14px 0}
.kpi-card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r);padding:14px}
.kpi-l{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.kpi-v{font-size:21px;font-weight:700;line-height:1;color:var(--text)}
.kpi-s{font-size:11px;color:var(--text3);margin-top:4px}
.up{color:var(--green)}
.card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:12px}
.card-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px}
.badge{display:inline-flex;font-size:11px;font-weight:600;padding:3px 9px;border-radius:99px;white-space:nowrap}
.bs{background:var(--gray-l);color:var(--gray-t)}.bt{background:var(--blue-l);color:var(--blue-t)}.bw{background:var(--amber-l);color:var(--amber-t)}.bb{background:var(--teal-l);color:var(--teal-t)}.bp{background:var(--purple-l);color:var(--purple-t)}.bg{background:var(--green-l);color:var(--green-t)}.br{background:var(--red-l);color:var(--red-t)}
.frow{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.flab{width:110px;font-size:12px;color:var(--text2);flex-shrink:0}
.ftrack{flex:1;height:14px;background:var(--surface2);border-radius:3px;overflow:hidden}
.ffill{height:100%;border-radius:3px}
.fnum{width:20px;text-align:right;font-size:12px;font-weight:700;flex-shrink:0}
.mgr-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:.5px solid var(--border)}
.mgr-row:last-child{border-bottom:none}
.avi{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.av-a{background:#EEF0FF;color:#4A3FB5}.av-b{background:#CCFBF1;color:#0F766E}
.mname{font-size:13px;font-weight:600}.mdeals{font-size:11px;color:var(--text3)}
.mstats{display:flex;gap:14px}
.sval{font-size:13px;font-weight:700;text-align:right}.slbl{font-size:10px;color:var(--text3);text-align:right}
.cpv-g{color:var(--green)}.cpv-m{color:var(--amber)}.cpv-b{color:var(--red)}
.pills{display:flex;gap:6px;overflow-x:auto;padding:12px 14px 8px;scrollbar-width:none;flex-shrink:0}
.pills::-webkit-scrollbar{display:none}
.pill{flex-shrink:0;padding:6px 13px;border-radius:99px;border:.5px solid var(--border2);font-size:12px;font-weight:500;color:var(--text2);white-space:nowrap}
.pill.on{background:var(--purple-l);color:var(--purple-t);border-color:#C5BCFF}
.deal-card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r);padding:13px 14px;margin:0 14px 10px;cursor:pointer}
.deal-card:active{border-color:var(--purple);background:var(--purple-l)}
.dc-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px}
.dc-name{font-size:14px;font-weight:600}
.dc-plat{font-size:11px;color:var(--text3);margin-top:1px}
.dc-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.dc-sum{font-size:13px;font-weight:600}.dc-mgr{font-size:11px;color:var(--text3)}.dc-cpv{font-size:12px;font-weight:600}
.b-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 14px}
.b-card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r);padding:13px}
.b-name{font-size:13px;font-weight:600;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.b-plat{font-size:11px;color:var(--text3);margin-bottom:9px}
.b-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px}
.b-l{color:var(--text3)}.b-v{font-weight:600}
.bud-item{border-bottom:.5px solid var(--border);padding:12px 0}
.bud-item:last-child{border-bottom:none}
.bud-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px}
.bud-name{font-size:13px;font-weight:600}.bud-sum{font-size:14px;font-weight:700}
.bud-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.bud-pay{font-size:11px;color:var(--text3)}.bud-tax{font-size:11px;color:var(--amber)}
.tg-hdr{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:11px;border-bottom:.5px solid #C3D9F5}
.tg-icon{width:36px;height:36px;background:#2AABEE;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;font-weight:700;flex-shrink:0}
.tg-wrap{background:#EEF6FF;border:.5px solid #C3D9F5;border-radius:var(--r);padding:14px;font-size:12px;line-height:1.7;white-space:pre-wrap;color:#1A2B3C;margin-bottom:12px}
.step{display:flex;gap:10px;margin-bottom:12px;align-items:flex-start}
.step-n{background:var(--purple-l);color:var(--purple-t);border-radius:6px;padding:2px 7px;font-size:12px;font-weight:700;flex-shrink:0;margin-top:1px}
.step-t{font-size:13px;color:var(--text2);line-height:1.5}
.drawer-overlay{position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:50;display:none}
.drawer-overlay.open{display:block}
.drawer{position:absolute;bottom:0;left:0;right:0;background:var(--surface);border-radius:18px 18px 0 0;z-index:51;transform:translateY(100%);transition:transform .25s cubic-bezier(.4,0,.2,1);max-height:80dvh;display:flex;flex-direction:column}
.drawer.open{transform:translateY(0)}
.drawer-handle{width:48px;height:5px;background:var(--border2);border-radius:3px;margin:10px auto 4px}
.drawer-hdr{padding:4px 16px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:.5px solid var(--border)}
.drawer-title{font-size:16px;font-weight:600}
.drawer-body{overflow-y:auto;padding:16px;flex:1}
.drawer-actions{padding:12px 16px;border-top:.5px solid var(--border);display:flex;gap:8px;flex-shrink:0}
.fg{margin-bottom:13px}
.fl{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:5px;display:block}
.fc{width:100%;height:44px;border:.5px solid var(--border2);border-radius:var(--rsm);padding:0 12px;font-size:15px;font-family:inherit;color:var(--text);background:var(--surface);outline:none;-webkit-appearance:none;appearance:none}
.fc:focus{border-color:var(--purple);box-shadow:0 0 0 3px var(--purple-l)}
.fg-2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn-p{background:var(--purple);color:#fff;border-radius:var(--rsm);padding:13px;font-size:15px;font-weight:600;flex:1;text-align:center;border:none;cursor:pointer}
.btn-g{background:none;border:.5px solid var(--border2);color:var(--text2);border-radius:var(--rsm);padding:13px;font-size:15px;font-weight:500;cursor:pointer}
.btn-danger{background:none;border:.5px solid var(--red-l);color:var(--red);border-radius:var(--rsm);padding:13px;font-size:15px;font-weight:500;cursor:pointer}
.pf{margin-bottom:14px}
.pfl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text3);margin-bottom:3px}
.pfv{font-size:15px;color:var(--text)}
.sep{height:.5px;background:var(--border);margin:14px 0}
.warn-box{background:var(--amber-l);border:.5px solid #FCD34D;border-radius:var(--rsm);padding:10px 12px;font-size:13px;color:var(--amber-t);margin-bottom:12px;display:none}
.warn-box.show{display:block}
.toast{position:absolute;bottom:76px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--text);color:#fff;padding:10px 18px;border-radius:99px;font-size:13px;font-weight:500;z-index:200;opacity:0;transition:all .2s;pointer-events:none;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.empty{text-align:center;padding:40px 20px;color:var(--text3);font-size:14px}
.contact-row{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:.5px solid var(--border);font-size:13px}
.contact-row:last-child{border-bottom:none}
.contact-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.contact-lbl{font-size:11px;color:var(--text3);min-width:60px}
.contact-val{color:var(--text);flex:1}
.delivery-badge{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;padding:4px 10px;border-radius:8px;margin-top:6px}
.del-ozon{background:#EEF0FF;color:#4A3FB5}
.del-wb{background:#F9ECFF;color:#7B2D8B}
.del-sdek{background:#E6F7F1;color:#006E46}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body>
<div class="shell">

<div class="hdr">
  <div>
    <div class="hdr-title" id="hdr-title">Дашборд</div>
    <div class="hdr-sub">Июнь 2026 · 2 менеджера</div>
  </div>
  <button class="hdr-btn" onclick="openNew()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
    Сделка
  </button>
</div>

<div class="scroll" id="scroll">

  <!-- DASHBOARD -->
  <div id="page-dash" class="page on">
    <div style="padding:0 14px 0;display:flex;align-items:center;gap:8px;overflow-x:auto;scrollbar-width:none;margin-bottom:10px">
      <div style="font-size:11px;font-weight:600;color:var(--text3);white-space:nowrap">Период:</div>
      <div id="dash-month-pills" style="display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;"></div>
    </div>
    <div class="kpi-grid" style="grid-template-columns:1fr 1fr 1fr">
      <div class="kpi-card"><div class="kpi-l">В работе</div><div class="kpi-v" id="k-total">—</div><div class="kpi-s"><span class="up">↑ 4</span> за неделю</div></div>
      <div class="kpi-card"><div class="kpi-l">Потрачено</div><div class="kpi-v" id="k-spent">—</div><div class="kpi-s">оплачено + размещено</div></div>
      <div class="kpi-card"><div class="kpi-l">Размещено</div><div class="kpi-v" id="k-placed">—</div><div class="kpi-s"><span class="up">↑ 3</span> за неделю</div></div>
      <div class="kpi-card"><div class="kpi-l">CPV по охвату</div><div class="kpi-v" id="k-cpv">—</div><div class="kpi-s">сумма ÷ ср. охват</div></div>
      <div class="kpi-card"><div class="kpi-l">CPV по просмотрам</div><div class="kpi-v" id="k-cpv2">—</div><div class="kpi-s">сумма ÷ просмотры факт</div></div>
    </div>
    <div style="padding:14px">
      <div class="card"><div class="card-title">Воронка</div><div id="funnel"></div></div>
      <div class="card"><div class="card-title">Менеджеры</div><div id="mgr-block"></div></div>
    </div>
    <div class="card-title" style="padding:0 14px 8px">Последние сделки</div>
    <div id="recent-list"></div>
    <div style="height:14px"></div>
  </div>

  <!-- DEALS -->
  <div id="page-deals" class="page" style="padding:0">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px 0">
      <div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em">Месяц</div>
    </div>
    <div class="pills" id="month-pills" style="padding:6px 14px 0"></div>
    <div class="pills" id="deal-pills">
      <button class="pill on" onclick="setDF('all',this)">Все</button>
      <button class="pill" onclick="setDF('Поиск',this)">Поиск</button>
      <button class="pill" onclick="setDF('Переговоры',this)">Переговоры</button>
      <button class="pill" onclick="setDF('Ожидает оплаты',this)">Ждёт оплаты</button>
      <button class="pill" onclick="setDF('Бартер',this)">Бартер</button>
      <button class="pill" onclick="setDF('Оплачено',this)">Оплачено</button>
      <button class="pill" onclick="setDF('Размещено',this)">Размещено</button>
      <button class="pill" onclick="setDF('Отказ',this)">Отказ</button>
    </div>
    <div id="deals-list"></div>
  </div>

  <!-- BLOGGERS -->
  <div id="page-bloggers" class="page" style="padding:0">
    <div class="pills" id="blog-pills">
      <button class="pill on" onclick="setBF('all',this)">Все</button>
      <button class="pill" onclick="setBF('Instagram',this)">Instagram</button>
      <button class="pill" onclick="setBF('Likee',this)">Likee</button>
      <button class="pill" onclick="setBF('TikTok',this)">TikTok</button>
      <button class="pill" onclick="setBF('Несколько',this)">Несколько</button>
      <button class="pill" onclick="setBF('__refused__',this)" style="border-color:var(--red-l);color:var(--red-t)">Не сложилось</button>
    </div>
    <div class="b-grid" id="blogger-grid"></div>
    <div style="height:14px"></div>
  </div>

  <!-- BUDGET -->
  <div id="page-budget" class="page" style="padding:0 14px">
    <!-- Budget plan input -->
    <div style="padding:14px 0 0">
      <div class="card" style="margin-bottom:0">
        <div class="card-title">Бюджет на месяц</div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
          <input class="fc" id="budget-plan" type="number" placeholder="500 000" inputmode="numeric" style="flex:1;height:44px;font-size:16px;font-weight:600" oninput="saveBudgetPlan();renderBudget()">
          <span style="font-size:15px;color:var(--text2);flex-shrink:0">₽</span>
        </div>
        <!-- Progress bar -->
        <div id="budget-progress-wrap" style="display:none">
          <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text3);margin-bottom:6px">
            <span>Использовано</span>
            <span id="budget-pct" style="font-weight:600"></span>
          </div>
          <div style="height:10px;background:var(--surface2);border-radius:5px;overflow:hidden">
            <div id="budget-bar" style="height:100%;border-radius:5px;transition:width .4s ease"></div>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-top:5px">
            <span id="budget-spent-lbl"></span>
            <span id="budget-remain-lbl"></span>
          </div>
        </div>
      </div>
    </div>

    <div class="kpi-grid" style="grid-template-columns:1fr 1fr;padding:12px 0 0">
      <div class="kpi-card"><div class="kpi-l">Оплачено</div><div class="kpi-v" id="b-paid" style="font-size:18px">—</div></div>
      <div class="kpi-card"><div class="kpi-l">Ожидает</div><div class="kpi-v" id="b-wait" style="font-size:18px;color:var(--amber)">—</div></div>
    </div>
    <div style="height:14px"></div>
    <div class="card"><div class="card-title">История оплат</div><div id="budget-list"></div></div>
  </div>

  <!-- TELEGRAM -->
  <div id="page-tg" class="page" style="padding:14px">
    <div class="tg-hdr">
      <div class="tg-icon">✈</div>
      <div><div style="font-weight:600;font-size:14px">Реклама · Аналитика</div><div style="font-size:11px;color:var(--text3)">Отчёт каждый день в 09:00</div></div>
    </div>
    <div class="tg-wrap" id="tg-prev"></div>
    <div class="card">
      <div class="card-title">Как подключить бота</div>
      <div class="step"><span class="step-n">1</span><span class="step-t">Создайте бота у <b>@BotFather</b> — получите токен</span></div>
      <div class="step"><span class="step-n">2</span><span class="step-t">Добавьте бота в вашу группу как администратора</span></div>
      <div class="step"><span class="step-n">3</span><span class="step-t">Вставьте токен в файл <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">telegram_bot.py</code></span></div>
      <div class="step"><span class="step-n">4</span><span class="step-t">Запустите: <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">python telegram_bot.py</code></span></div>
      <div class="step"><span class="step-n">5</span><span class="step-t">Напишите <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">/stats</code> в группе — бот ответит</span></div>
      <div style="background:var(--amber-l);border-radius:var(--rsm);padding:10px 12px;font-size:12px;color:var(--amber-t);margin-top:4px">💡 Отчёт формируется из ваших данных автоматически каждое утро</div>
    </div>
  </div>

  <!-- SETTINGS -->
  <div id="page-settings" class="page" style="padding:14px">

    <!-- Менеджеры -->
    <div class="card">
      <div class="card-title">👤 Менеджеры</div>
      <div id="s-mgr-list"></div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <input class="fc" id="s-mgr-input" placeholder="Имя менеджера" style="flex:1;height:40px">
        <button onclick="sAdd('mgr')" style="background:var(--purple);color:#fff;border-radius:var(--rsm);padding:0 16px;font-size:13px;font-weight:600;white-space:nowrap">+ Добавить</button>
      </div>
    </div>

    <!-- Продукты -->
    <div class="card">
      <div class="card-title">📦 Продукты</div>
      <div id="s-prod-list"></div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <input class="fc" id="s-prod-input" placeholder="Название продукта" style="flex:1;height:40px">
        <button onclick="sAdd('prod')" style="background:var(--purple);color:#fff;border-radius:var(--rsm);padding:0 16px;font-size:13px;font-weight:600;white-space:nowrap">+ Добавить</button>
      </div>
    </div>

    <!-- Платформы -->
    <div class="card">
      <div class="card-title">📱 Платформы</div>
      <div id="s-plat-list"></div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <input class="fc" id="s-plat-input" placeholder="Название платформы" style="flex:1;height:40px">
        <button onclick="sAdd('plat')" style="background:var(--purple);color:#fff;border-radius:var(--rsm);padding:0 16px;font-size:13px;font-weight:600;white-space:nowrap">+ Добавить</button>
      </div>
    </div>

    <!-- Типы оплаты -->
    <div class="card">
      <div class="card-title">💳 Типы оплаты</div>
      <div id="s-pay-list"></div>
      <div style="display:flex;gap:8px;margin-top:12px">
