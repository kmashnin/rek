function load(){
  try{
    const d=localStorage.getItem('deals_v2');
    const b=localStorage.getItem('blogs_v2');
    return{
      deals:d?JSON.parse(d):JSON.parse(JSON.stringify(INIT_DEALS)),
      blogs:b?JSON.parse(b):JSON.parse(JSON.stringify(INIT_BLOGGERS))
    };
  }catch(e){return{deals:JSON.parse(JSON.stringify(INIT_DEALS)),blogs:JSON.parse(JSON.stringify(INIT_BLOGGERS))};}
}
function save(){
  try{localStorage.setItem('deals_v2',JSON.stringify(state.deals));localStorage.setItem('blogs_v2',JSON.stringify(state.blogs));}catch(e){}
}
let state=load();
let dF='all',bF='all',aDId=null,activeMth='all';

const fmt=n=>n?n.toLocaleString('ru-RU'):'—';
const fR=n=>n?n.toLocaleString('ru-RU')+' ₽':'—';
const cC=v=>!v?'':v<0.4?'cpv-g':v<0.8?'cpv-m':'cpv-b';
const bdg=s=>`<span class="badge ${SC[s]||'bs'}">${s}</span>`;

// CPV по охвату = сумма / средний охват
function calcCPVReach(d){
  if(!d.s||!d.reach)return null;
  return d.s/d.reach;
}
// CPV по просмотрам = сумма / просмотры факт
function calcCPVViews(d){
  if(!d.s||!d.v)return null;
  return d.s/d.v;
}
// для карточки показываем оба (приоритет — просмотры, если есть)
function calcCPV(d){
  return calcCPVViews(d)||calcCPVReach(d);
}

function renderDash(){
  renderMonthPills('dash-month-pills');
  const d=filterByMonth(state.deals);
  const placed=d.filter(x=>x.st==='Размещено');
  const spent=d.filter(x=>['Оплачено','Размещено'].includes(x.st)).reduce((a,x)=>a+x.s,0);
  // avg CPV по охвату
  const placedWithReach=placed.filter(x=>x.s&&x.reach);
  const avgCPVReach=placedWithReach.length?placedWithReach.reduce((a,x)=>a+x.s/x.reach,0)/placedWithReach.length:null;
  // avg CPV по просмотрам
  const placedWithViews=placed.filter(x=>x.s&&x.v);
  const avgCPVViews=placedWithViews.length?placedWithViews.reduce((a,x)=>a+x.s/x.v,0)/placedWithViews.length:null;

  document.getElementById('k-total').textContent=d.length;
  document.getElementById('k-spent').textContent=fR(spent);
  document.getElementById('k-placed').textContent=placed.length;
  document.getElementById('k-cpv').textContent=avgCPVReach?avgCPVReach.toFixed(2)+' ₽':'—';
  document.getElementById('k-cpv2').textContent=avgCPVViews?avgCPVViews.toFixed(2)+' ₽':'—';

  const sts=['Поиск','Переговоры','Ожидает оплаты','Бартер','Оплачено','Размещено','Отказ'];
  const cnt={};sts.forEach(s=>cnt[s]=d.filter(x=>x.st===s).length);
  const mx=Math.max(...Object.values(cnt),1);
  document.getElementById('funnel').innerHTML=sts.map(s=>`<div class="frow"><div class="flab">${s}</div><div class="ftrack"><div class="ffill" style="width:${Math.round(cnt[s]/mx*100)}%;background:${FC[s]}"></div></div><div class="fnum">${cnt[s]}</div></div>`).join('');

  document.getElementById('mgr-block').innerHTML=MGRS.map((m,i)=>{
    const md=d.filter(x=>x.m===m);
    const ms=md.filter(x=>['Оплачено','Размещено'].includes(x.st)).reduce((a,x)=>a+x.s,0);
    const mPlaced=md.filter(x=>x.st==='Размещено'&&x.s&&x.reach);
    const mc=mPlaced.length?(mPlaced.reduce((a,x)=>a+x.s/x.reach,0)/mPlaced.length).toFixed(2)+' ₽':'—';
    const mcl=mPlaced.length?cC(mPlaced.reduce((a,x)=>a+x.s/x.reach,0)/mPlaced.length):'';
    return`<div class="mgr-row"><div style="display:flex;align-items:center;gap:9px"><div class="avi ${AV_CLS[i]}">${AV_INI[i]}</div><div><div class="mname">${m}</div><div class="mdeals">${md.length} сделок</div></div></div><div class="mstats"><div><div class="sval">${fR(ms)}</div><div class="slbl">потрачено</div></div><div><div class="sval ${mcl}">${mc}</div><div class="slbl">CPV</div></div></div></div>`;
  }).join('');

  const rec=[...d].slice(-5).reverse();
  document.getElementById('recent-list').innerHTML=rec.map(d=>dealCard(d)).join('');
}

function dealCard(d){
  const cpv=calcCPV(d);
  return`<div class="deal-card" onclick="openDet(${d.id})">
    <div class="dc-top"><div><div class="dc-name">${d.b}</div><div class="dc-plat">${d.pl} · ${d.m}</div></div>${bdg(d.st)}</div>
    <div class="dc-meta">
      <span class="dc-sum">${d.s?fR(d.s):'Бартер'}</span>
      <span class="dc-mgr">${d.pr}</span>
      ${calcCPVViews(d)?`<span class="dc-cpv ${cC(calcCPVViews(d))}">👁 ${calcCPVViews(d).toFixed(2)} ₽</span>`:''}
      ${calcCPVReach(d)&&!calcCPVViews(d)?`<span class="dc-cpv ${cC(calcCPVReach(d))}">📊 ${calcCPVReach(d).toFixed(2)} ₽</span>`:''}
      ${d.del?`<span style="font-size:11px;color:var(--text3)">${DEL_ICON[d.del]||''} ${DEL_LABELS[d.del]||''}</span>`:''}
    </div>
  </div>`;
}

function renderDeals(){
  renderMonthPills('month-pills');
  const rows=filterByMonth(state.deals).filter(d=>dF==='all'||d.st===dF);
  document.getElementById('deals-list').innerHTML=rows.length?rows.map(d=>dealCard(d)).join(''):'<div class="empty">Нет сделок по фильтру</div>';
}

function renderBloggers(){
  // sort alphabetically
  const q2=(document.getElementById('b-search')||{}).value||'';
  const rows=[...state.blogs].filter(b=>{
    if(bF==='__refused__') return !!b.reason;
    return (bF==='all'||b.pl===bF)&&(!q2||b.n.toLowerCase().includes(q2.toLowerCase()));
  }).sort((a,b)=>a.n.replace('@','').localeCompare(b.n.replace('@',''),'ru'));
  document.getElementById('blogger-grid').innerHTML=rows.map(b=>{
    // CPV from deals
    const bd=state.deals.filter(x=>x.b===b.n&&x.s&&x.reach);
    const cpv=bd.length?bd.reduce((a,x)=>a+x.s/x.reach,0)/bd.length:null;
    const ct=cpv?cpv.toFixed(2)+' ₽':'—';const cc=cpv?cC(cpv):'';
    const reach=b.reach?fmt(b.reach):b.sb?fmt(b.sb):'—';
    const reasonBadge=b.reason?`<div style="margin-top:8px"><span style="background:var(--red-l);color:var(--red-t);font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px">${b.reason}</span></div>`:'';
    return`<div class="b-card"><div class="b-name">${b.n}</div><div class="b-plat">${b.pl}</div>
      <div class="b-row"><span class="b-l">Ср. охват</span><span class="b-v">${reach}</span></div>
      <div class="b-row"><span class="b-l">CPV</span><span class="b-v ${cc}">${ct}</span></div>
      <div class="b-row"><span class="b-l">Цена</span><span class="b-v">${b.p}</span></div>
      <div class="b-row"><span class="b-l">Размещ.</span><span class="b-v">${b.d}</span></div>
      ${reasonBadge}
      ${b.c?`<div style="margin-top:6px;font-size:10px;color:var(--text3);line-height:1.4">${b.c}</div>`:''}
    </div>`;
  }).join('');
}

